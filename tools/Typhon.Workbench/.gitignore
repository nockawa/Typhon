# Build artifacts (generated on `dotnet build` and `vite build`)
wwwroot/
ClientApp/node_modules/
ClientApp/dist/
ClientApp/.vite/
ClientApp/*.tsbuildinfo

# Orval-generated API surface (regenerated by `npm run generate-types`)
ClientApp/src/api/generated/
ClientApp/src/api/model/
ClientApp/src/api/typhon-workbench/

# Playwright artifacts (regenerated on every e2e run)
ClientApp/playwright-report/
ClientApp/test-results/
ClientApp/blob-report/
ClientApp/.playwright-cache/
