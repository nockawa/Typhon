  "components": {
    "schemas": {
      "ArchetypeDto": {
        "required": [
          "archetypeId",
          "name"
        ],
        "type": "object",
        "properties": {
          "archetypeId": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "uint16"
          },
          "name": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "ArchetypeInfoDto": {
        "required": [
          "archetypeId",
          "componentTypes",
          "entityCount",
          "componentSize",
          "storageMode",
          "chunkCount",
          "chunkCapacity",
          "occupancyPct"
        ],
        "type": "object",
        "properties": {
          "archetypeId": {
            "type": [
              "null",
              "string"
            ]
          },
          "componentTypes": {
            "type": [
              "null",
              "array"
            ],
            "items": {
              "type": "string"
            }
          },
          "entityCount": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int64"
          },
          "componentSize": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
