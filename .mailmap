# .mailmap - Normalizes author names in git log/blame/shortlog
#
# This file maps all variations of author names to a canonical form.
# Format: Canonical Name <canonical@email> Commit Name <commit@email>
#
# All commits will display as "nockawa <loic.baumann@outlook.com>"

# Map "Loïc Baumann" variations to "nockawa"
nockawa <loic.baumann@outlook.com> Loïc Baumann <loic.baumann@outlook.com>
nockawa <loic.baumann@outlook.com> Loic Baumann <loic.baumann@outlook.com>

# Map the unity3d.com email to the canonical outlook.com email
nockawa <loic.baumann@outlook.com> Loïc Baumann <loic.baumann@unity3d.com>

# Map GitHub noreply email to canonical email
nockawa <loic.baumann@outlook.com> nockawa <nockawa@users.noreply.github.com>

# Canonical identity (this line ensures "nockawa" commits stay as-is)
nockawa <loic.baumann@outlook.com>
