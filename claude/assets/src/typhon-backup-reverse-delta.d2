# Typhon: Reverse Delta Chain — Snapshot Management
# Shows how reverse deltas work for incremental backups

direction: right

# ── Title ─────────────────────────────────────────────────────
title: "Reverse Delta Chain — Snapshot Strategy" {
  shape: text
  style.font-size: 22
  style.bold: true
  style.font-color: "#37474f"
  near: top-center
}

# ── Timeline ─────────────────────────────────────────────────
chain: "" {
  style.fill: "#fafafa"
  style.stroke: "#607d8b"
  style.border-radius: 10

  s3: "Snapshot 3\n(FULL — latest state)\nAll pages compressed" {
    shape: rectangle
    style.fill: "#a5d6a7"
    style.stroke: "#2e7d32"
    style.border-radius: 8
    style.bold: true
  }

  s2: "Snapshot 2\n(Reverse Delta)\nΔ to go from S3→S2" {
    shape: rectangle
    style.fill: "#ffe0b2"
    style.stroke: "#e65100"
    style.border-radius: 8
  }

  s1: "Snapshot 1\n(Reverse Delta)\nΔ to go from S2→S1" {
    shape: rectangle
    style.fill: "#ffcc80"
    style.stroke: "#e65100"
    style.border-radius: 8
  }

  s3 -> s2: "apply Δ₂" {style.stroke: "#e65100"; style.bold: true}
  s2 -> s1: "apply Δ₁" {style.stroke: "#e65100"}
}

# ── Operations ───────────────────────────────────────────────
ops: "Operations" {
  style.fill: "#e3f2fd"
  style.stroke: "#1565c0"
  style.border-radius: 10

  restore_latest: "Restore Latest\nRead S3 directly\n(instant)" {
    shape: rectangle
    style.fill: "#bbdefb"
    style.stroke: "#1976d2"
    style.border-radius: 6
    style.bold: true
  }

  restore_old: "Restore S1\nS3 → apply Δ₂ → apply Δ₁\n(slower)" {
    shape: rectangle
    style.fill: "#90caf9"
    style.stroke: "#1565c0"
    style.border-radius: 6
  }

  delete_old: "Delete S1\nJust remove Δ₁ file\n(no cascade!)" {
    shape: rectangle
    style.fill: "#c8e6c9"
    style.stroke: "#2e7d32"
    style.border-radius: 6
    style.bold: true
  }

  new_snap: "New Snapshot S4\nS3 becomes Δ₃ (reverse delta)\nS4 becomes new FULL" {
    shape: rectangle
    style.fill: "#f8bbd0"
    style.stroke: "#c62828"
    style.border-radius: 6
  }
}

# ── Connections ──────────────────────────────────────────────
ops.restore_latest -> chain.s3: "direct read" {
  style.stroke: "#2e7d32"
  style.bold: true
}
ops.restore_old -> chain.s3: "start here" {
  style.stroke: "#1565c0"
  style.stroke-dash: 3
}
ops.delete_old -> chain.s1: "remove" {
  style.stroke: "#c62828"
  style.stroke-dash: 3
}
