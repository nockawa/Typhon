# Typhon: Resource Tree Topology
# Final agreed structure showing what IS and IS NOT a graph node
# Segments follow "Owner Aggregates" pattern (NOT graph nodes)

direction: down

# ── Title ─────────────────────────────────────────────────────
title: "Resource Tree — Final Topology" {
  shape: text
  style.font-size: 20
  style.bold: true
  style.font-color: "#37474f"
  near: top-center
}

# ── Legend ────────────────────────────────────────────────────
legend: "Legend" {
  style.fill: "#fafafa"
  style.stroke: "#9e9e9e"
  style.border-radius: 6
  grid-columns: 2

  node_example: "Graph Node\n[Metric Kinds]" {
    shape: rectangle
    style.fill: "#e3f2fd"
    style.stroke: "#1565c0"
    style.font-size: 11
    style.border-radius: 4
  }
  agg_example: "(AGGREGATED)\nnot a node" {
    shape: rectangle
    style.fill: "#f5f5f5"
    style.stroke: "#bdbdbd"
    style.stroke-dash: 3
    style.font-size: 11
    style.border-radius: 4
  }
}

# ── Root ─────────────────────────────────────────────────────
root: "Root" {
  shape: rectangle
  style.fill: "#e8eaf6"
  style.stroke: "#283593"
  style.bold: true
  style.border-radius: 6
}

# ── Storage ──────────────────────────────────────────────────
storage: "Storage" {
  shape: rectangle
  style.fill: "#fff3e0"
  style.stroke: "#e65100"
  style.bold: true
  style.border-radius: 6
}
page_cache: "PageCache\n[Memory, Capacity,\nDiskIO, Contention,\nThroughput]" {
  shape: rectangle
  style.fill: "#ffe0b2"
  style.stroke: "#e65100"
  style.font-size: 12
  style.bold: true
}
mmf: "ManagedPagedMMF\n[Memory, Capacity,\nDiskIO]" {
  shape: rectangle
  style.fill: "#ffe0b2"
  style.stroke: "#e65100"
  style.font-size: 12
}

# ── DataEngine ───────────────────────────────────────────────
data: "DataEngine" {
  shape: rectangle
  style.fill: "#e3f2fd"
  style.stroke: "#1565c0"
  style.bold: true
  style.border-radius: 6
}
tx_pool: "TransactionPool\n[Capacity, Throughput,\nDuration]" {
  shape: rectangle
  style.fill: "#bbdefb"
  style.stroke: "#1976d2"
  style.font-size: 12
}
comp_table: "ComponentTable<T>\n[Memory, Contention,\nCapacity, Throughput]" {
  shape: rectangle
  style.fill: "#bbdefb"
  style.stroke: "#1976d2"
  style.font-size: 12
  style.bold: true
}
pk_idx: "PrimaryKeyIndex\n[Capacity, Throughput,\nDuration]" {
  shape: rectangle
  style.fill: "#e1f5fe"
  style.stroke: "#0277bd"
  style.font-size: 11
}
sec_idx: "SecondaryIndex<F>\n[Capacity, Throughput]" {
  shape: rectangle
  style.fill: "#e1f5fe"
  style.stroke: "#0277bd"
  style.font-size: 11
}

# ── Segments (AGGREGATED - NOT GRAPH NODES) ──────────────────
segments: "(Segments: AGGREGATED via IDebugPropertiesProvider)" {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#bdbdbd"
  style.stroke-dash: 3
  style.font-size: 10
  style.font-color: "#757575"
  style.border-radius: 4

  inner_segs: "ComponentSegment | CompRevTableSegment\nDefaultIndexSegment | String64IndexSegment" {
    shape: text
    style.font-size: 10
    style.font-color: "#9e9e9e"
  }
}

# ── Durability ───────────────────────────────────────────────
durability: "Durability" {
  shape: rectangle
  style.fill: "#fce4ec"
  style.stroke: "#c62828"
  style.bold: true
  style.border-radius: 6
}
wal_ring: "WALRingBuffer\n[Memory, Capacity,\nThroughput, Contention]" {
  shape: rectangle
  style.fill: "#f8bbd0"
  style.stroke: "#c62828"
  style.font-size: 12
  style.bold: true
}
wal_segs: "WALSegments\n[DiskIO, Capacity]" {
  shape: rectangle
  style.fill: "#f8bbd0"
  style.stroke: "#c62828"
  style.font-size: 12
}
checkpoint: "Checkpoint\n[Throughput, Duration,\nDiskIO]" {
  shape: rectangle
  style.fill: "#f8bbd0"
  style.stroke: "#c62828"
  style.font-size: 12
}
uow_epoch: "UoWEpochRegistry\n[Capacity]" {
  shape: rectangle
  style.fill: "#f8bbd0"
  style.stroke: "#c62828"
  style.font-size: 12
}

# ── Backup ───────────────────────────────────────────────────
backup: "Backup" {
  shape: rectangle
  style.fill: "#e8f5e9"
  style.stroke: "#2e7d32"
  style.bold: true
  style.border-radius: 6
}
shadow_buf: "ShadowBuffer\n[Memory, Capacity,\nContention]" {
  shape: rectangle
  style.fill: "#c8e6c9"
  style.stroke: "#2e7d32"
  style.font-size: 12
}
snap_store: "SnapshotStore\n[DiskIO, Capacity]" {
  shape: rectangle
  style.fill: "#c8e6c9"
  style.stroke: "#2e7d32"
  style.font-size: 12
}

# ── Allocation ──────────────────────────────────────────────
allocation: "Allocation" {
  shape: rectangle
  style.fill: "#f3e5f5"
  style.stroke: "#6a1b9a"
  style.bold: true
  style.border-radius: 6
}
mem_alloc: "MemoryAllocator\n[Memory, Throughput]" {
  shape: rectangle
  style.fill: "#e1bee7"
  style.stroke: "#6a1b9a"
  style.font-size: 12
}
mem_block: "PinnedMemoryBlock[]\n[Memory]" {
  shape: rectangle
  style.fill: "#f3e5f5"
  style.stroke: "#7b1fa2"
  style.font-size: 11
}

# ── Tree Edges ───────────────────────────────────────────────
root -> storage: "" {style.stroke: "#283593"}
root -> data: "" {style.stroke: "#283593"}
root -> durability: "" {style.stroke: "#283593"}
root -> backup: "" {style.stroke: "#283593"}
root -> allocation: "" {style.stroke: "#283593"}

storage -> page_cache: "" {style.stroke: "#e65100"}
storage -> mmf: "" {style.stroke: "#e65100"}

data -> tx_pool: "" {style.stroke: "#1565c0"}
data -> comp_table: "" {style.stroke: "#1565c0"}
comp_table -> pk_idx: "" {style.stroke: "#0277bd"}
comp_table -> sec_idx: "" {style.stroke: "#0277bd"}
comp_table -> segments: "aggregates\n(not child nodes)" {
  style.stroke: "#bdbdbd"
  style.stroke-dash: 3
  style.font-size: 10
}

durability -> wal_ring: "" {style.stroke: "#c62828"}
durability -> wal_segs: "" {style.stroke: "#c62828"}
durability -> checkpoint: "" {style.stroke: "#c62828"}
durability -> uow_epoch: "" {style.stroke: "#c62828"}

backup -> shadow_buf: "" {style.stroke: "#2e7d32"}
backup -> snap_store: "" {style.stroke: "#2e7d32"}

allocation -> mem_alloc: "" {style.stroke: "#6a1b9a"}
mem_alloc -> mem_block: "" {style.stroke: "#7b1fa2"}

# ── Design Notes ─────────────────────────────────────────────
note: |md
  **Granularity Rules (05-granularity-strategy.md)**
  - Target depth: 3 levels (4 only when justified)
  - Segments: Owner Aggregates (ComponentTable aggregates)
  - Latches/chunks: never graph nodes
  - Memory blocks: yes (bounded count, distinct lifecycle)
| {
  shape: text
  style.font-size: 11
  style.font-color: "#546e7a"
  near: bottom-left
}
