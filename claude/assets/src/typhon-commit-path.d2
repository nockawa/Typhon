# Typhon: Transaction Commit Path
# Shows the flow from tx.Commit() through WAL to durable storage

direction: down

title: |md
  # Transaction Commit Path
  From tx.Commit() to durable storage
| {
  shape: text
  near: top-center
}

# ══════════════════════════════════════════════════════════════
# TOP ROW: Application initiates commit
# ══════════════════════════════════════════════════════════════

app: "Application Thread" {
  style.fill: "#e3f2fd"
  style.stroke: "#1565c0"
  style.border-radius: 8

  uow: "UnitOfWork\n(DurabilityMode)" {
    shape: rectangle
    style.fill: "#bbdefb"
    style.border-radius: 6
  }
  tx: "Transaction" {
    shape: rectangle
    style.fill: "#90caf9"
    style.border-radius: 6
  }
  commit: "tx.Commit()" {
    shape: rectangle
    style.fill: "#1565c0"
    style.font-color: white
    style.bold: true
    style.border-radius: 6
  }

  uow -> tx: "creates"
  tx -> commit: "calls"
}

# ══════════════════════════════════════════════════════════════
# MIDDLE: Commit Pipeline (the core logic)
# ══════════════════════════════════════════════════════════════

pipeline: "Commit Pipeline" {
  style.fill: "#fff3e0"
  style.stroke: "#e65100"
  style.border-radius: 8

  conflict: "1. MVCC Conflict\nDetection" {
    shape: rectangle
    style.fill: "#ffe0b2"
    style.border-radius: 6
  }

  stamp: "2. Stamp UoW ID\non Revisions" {
    shape: rectangle
    style.fill: "#ffcc80"
    style.border-radius: 6
  }

  serialize: "3. Serialize WAL\nRecord" {
    shape: rectangle
    style.fill: "#ffb74d"
    style.border-radius: 6
  }

  decide: "4. Durability\nDecision" {
    shape: diamond
    style.fill: "#e65100"
    style.font-color: white
    style.bold: true
  }

  conflict -> stamp: "pass"
  stamp -> serialize
  serialize -> decide
}

# ══════════════════════════════════════════════════════════════
# BOTTOM LEFT: WAL Pipeline (durability path)
# ══════════════════════════════════════════════════════════════

wal: "WAL Pipeline" {
  style.fill: "#fce4ec"
  style.stroke: "#c62828"
  style.border-radius: 8

  ring: "Ring Buffer\n(MPSC, 1-4MB)" {
    shape: queue
    style.fill: "#f8bbd0"
  }

  writer: "WAL Writer\n(dedicated thread)" {
    shape: rectangle
    style.fill: "#f48fb1"
    style.bold: true
    style.border-radius: 6
  }

  segment: "WAL Segment\n(4MB, FUA)" {
    shape: page
    style.fill: "#c62828"
    style.font-color: white
  }

  ring -> writer: "drain"
  writer -> segment: "FUA\n10-80µs"
}

# ══════════════════════════════════════════════════════════════
# BOTTOM RIGHT: Checkpoint Pipeline (space reclamation)
# ══════════════════════════════════════════════════════════════

checkpoint: "Checkpoint Pipeline" {
  style.fill: "#e8f5e9"
  style.stroke: "#2e7d32"
  style.border-radius: 8

  pages: "Dirty Pages\n(Page Cache)" {
    shape: cylinder
    style.fill: "#c8e6c9"
  }

  cp_mgr: "Checkpoint\nManager" {
    shape: rectangle
    style.fill: "#a5d6a7"
    style.border-radius: 6
  }

  data: "Data File\n(8KB pages)" {
    shape: page
    style.fill: "#2e7d32"
    style.font-color: white
  }

  pages -> cp_mgr: "every 10s"
  cp_mgr -> data: "fsync"
}

# ══════════════════════════════════════════════════════════════
# CONNECTIONS: Main flow
# ══════════════════════════════════════════════════════════════

# App to Pipeline
app.commit -> pipeline.conflict: "~1-2µs" {
  style.stroke: "#1565c0"
  style.bold: true
}

# Pipeline branches based on durability mode
pipeline.decide -> wal.ring: "Immediate:\nwait for FUA" {
  style.stroke: "#c62828"
  style.bold: true
}

pipeline.decide -> app: "Deferred/GroupCommit:\nreturn immediately" {
  style.stroke: "#2e7d32"
  style.stroke-dash: 5
}

# Serialize always writes to ring buffer
pipeline.serialize -> wal.ring: "atomic\nXADD" {
  style.stroke: "#e65100"
  style.stroke-dash: 3
}

# WAL to Checkpoint (async, background)
wal.segment -> checkpoint.pages: "revisions\nvisible" {
  style.stroke: "#9c27b0"
  style.stroke-dash: 5
}

# Recycling feedback
checkpoint.data -> wal.segment: "enables\nrecycling" {
  style.stroke: "#757575"
  style.stroke-dash: 5
}


