# Typhon: Resource Graph — Component Overview
# Shows the hierarchical tree structure with metric kinds per node

direction: down

# ── Title ─────────────────────────────────────────────────────
title: "Resource Graph — Component Overview" {
  shape: text
  style.font-size: 22
  style.bold: true
  style.font-color: "#37474f"
  near: top-center
}

# ── Root ──────────────────────────────────────────────────────
root: "ResourceRegistry\n(Root)" {
  style.fill: "#e8eaf6"
  style.stroke: "#283593"
  style.border-radius: 10
  style.bold: true
  grid-columns: 3

  # ── Storage Subtree ──────────────────────────────────────────
  storage: "Storage" {
    style.fill: "#fff3e0"
    style.stroke: "#e65100"
    style.border-radius: 8

    page_cache: "PageCache\n[Memory, Capacity,\nDiskIO, Contention]" {
      shape: rectangle
      style.fill: "#ffe0b2"
      style.stroke: "#e65100"
      style.bold: true
    }
    seg_mgr: "SegmentManager\n[Capacity, Throughput]" {
      shape: rectangle
      style.fill: "#ffe0b2"
      style.stroke: "#e65100"
    }
    chunk_cache: "ChunkAccessorCache\n[Capacity, Throughput]" {
      shape: rectangle
      style.fill: "#ffe0b2"
      style.stroke: "#e65100"
    }

    seg_mgr.segments: "ComponentSegment<T>\nRevisionSegment<T>\nIndexSegment<T>\n[Memory, Capacity]" {
      shape: rectangle
      style.fill: "#fff8e1"
      style.stroke: "#ff8f00"
      style.font-size: 12
    }
  }

  # ── DataEngine Subtree ───────────────────────────────────────
  data: "DataEngine" {
    style.fill: "#e3f2fd"
    style.stroke: "#1565c0"
    style.border-radius: 8

    tx_pool: "TransactionPool\n[Capacity, Throughput,\nDuration]" {
      shape: rectangle
      style.fill: "#bbdefb"
      style.stroke: "#1976d2"
      style.bold: true
    }
    comp_table: "ComponentTable<T>\n[Memory, Contention,\nThroughput]" {
      shape: rectangle
      style.fill: "#bbdefb"
      style.stroke: "#1976d2"
    }

    comp_table.pk_idx: "PrimaryKeyIndex\n[Capacity, Throughput,\nDuration]" {
      shape: rectangle
      style.fill: "#e1f5fe"
      style.stroke: "#0277bd"
      style.font-size: 12
    }
    comp_table.sec_idx: "SecondaryIndex<F>\n[Capacity, Throughput]" {
      shape: rectangle
      style.fill: "#e1f5fe"
      style.stroke: "#0277bd"
      style.font-size: 12
    }
  }

  # ── Durability Subtree ───────────────────────────────────────
  durability: "Durability" {
    style.fill: "#fce4ec"
    style.stroke: "#c62828"
    style.border-radius: 8

    wal_ring: "WALRingBuffer\n[Memory, Capacity,\nContention, Throughput]" {
      shape: rectangle
      style.fill: "#f8bbd0"
      style.stroke: "#c62828"
      style.bold: true
    }
    wal_segs: "WALSegments\n[DiskIO, Capacity]" {
      shape: rectangle
      style.fill: "#f8bbd0"
      style.stroke: "#c62828"
    }
    checkpoint: "Checkpoint\n[Throughput, Duration,\nDiskIO]" {
      shape: rectangle
      style.fill: "#f8bbd0"
      style.stroke: "#c62828"
    }
  }

  # ── Backup Subtree ──────────────────────────────────────────
  backup: "Backup" {
    style.fill: "#e8f5e9"
    style.stroke: "#2e7d32"
    style.border-radius: 8

    shadow_buf: "ShadowBuffer\n[Memory, Capacity,\nContention]" {
      shape: rectangle
      style.fill: "#c8e6c9"
      style.stroke: "#2e7d32"
    }
    snap_store: "SnapshotStore\n[DiskIO, Capacity]" {
      shape: rectangle
      style.fill: "#c8e6c9"
      style.stroke: "#2e7d32"
    }
  }

  # ── Allocation Subtree ──────────────────────────────────────
  alloc: "Allocation" {
    style.fill: "#f3e5f5"
    style.stroke: "#6a1b9a"
    style.border-radius: 8

    mem_alloc: "MemoryAllocator\n[Memory, Throughput]" {
      shape: rectangle
      style.fill: "#e1bee7"
      style.stroke: "#6a1b9a"
    }
    block_alloc: "BlockAllocators\n[Capacity, Throughput]" {
      shape: rectangle
      style.fill: "#e1bee7"
      style.stroke: "#6a1b9a"
    }
  }
}

# ── Snapshot Output ────────────────────────────────────────────
snapshot: "GetSnapshot()\n~5–10 μs for 50–100 nodes" {
  shape: rectangle
  style.fill: "#eceff1"
  style.stroke: "#455a64"
  style.bold: true
  style.border-radius: 6
}

root -> snapshot: "pull-based\non demand" {
  style.stroke: "#455a64"
  style.bold: true
  style.stroke-dash: 4
}

# ── Legend ─────────────────────────────────────────────────────
legend: "Metric Kinds" {
  style.fill: "#fafafa"
  style.stroke: "#9e9e9e"
  style.border-radius: 6
  grid-columns: 6

  m: "Memory\nbytes owned\n(allocated/peak)" {
    shape: rectangle
    style.fill: "#fafafa"
    style.stroke: "#bdbdbd"
    style.font-size: 12
    style.border-radius: 4
  }
  c: "Capacity\nslots used vs max\n(utilization)" {
    shape: rectangle
    style.fill: "#fafafa"
    style.stroke: "#bdbdbd"
    style.font-size: 12
    style.border-radius: 4
  }
  d: "DiskIO\nread/write ops\nand bytes" {
    shape: rectangle
    style.fill: "#fafafa"
    style.stroke: "#bdbdbd"
    style.font-size: 12
    style.border-radius: 4
  }
  n: "Contention\nlock wait\ncount/duration" {
    shape: rectangle
    style.fill: "#fafafa"
    style.stroke: "#bdbdbd"
    style.font-size: 12
    style.border-radius: 4
  }
  t: "Throughput\nops/sec\n(monotonic counters)" {
    shape: rectangle
    style.fill: "#fafafa"
    style.stroke: "#bdbdbd"
    style.font-size: 12
    style.border-radius: 4
  }
  u: "Duration\noperation time\n(last/avg/max)" {
    shape: rectangle
    style.fill: "#fafafa"
    style.stroke: "#bdbdbd"
    style.font-size: 12
    style.border-radius: 4
  }
}

# Force legend below snapshot
snapshot -> legend: "" {
  style.stroke: "#9e9e9e"
  style.stroke-dash: 5
  style.opacity: 0.3
}
