# Typhon: Shared Utilities — Component Overview
# Shows utility categories and their consumers across all components

direction: down

# ── Title ─────────────────────────────────────────────────────
title: "Shared Utilities — Dependency Map" {
  shape: text
  style.font-size: 22
  style.bold: true
  style.font-color: "#37474f"
  near: top-center
}

# ── Consumer Components (horizontal row on top) ──────────────
consumers: "Consumer Components" {
  style.fill: "#e8eaf6"
  style.stroke: "#283593"
  style.border-radius: 10
  grid-columns: 1

  concurrency: "1. Concurrency" {
    shape: rectangle
    style.fill: "#c5cae9"
    style.stroke: "#3949ab"
    style.bold: true
    style.border-radius: 4
  }
  storage: "3. Storage" {
    shape: rectangle
    style.fill: "#c5cae9"
    style.stroke: "#3949ab"
    style.bold: true
    style.border-radius: 4
  }
  data: "4. Data" {
    shape: rectangle
    style.fill: "#c5cae9"
    style.stroke: "#3949ab"
    style.bold: true
    style.border-radius: 4
  }
  query: "5. Query" {
    shape: rectangle
    style.fill: "#c5cae9"
    style.stroke: "#3949ab"
    style.bold: true
    style.border-radius: 4
  }
}

# ── Utility Categories (horizontal row below) ────────────────
utilities: "Shared Utilities (by category)" {
  style.fill: "#fafafa"
  style.stroke: "#616161"
  style.border-radius: 10
  grid-columns: 1

  types: "A. Type Utilities\nString64, String1024\nVariant, Point2/3/4\nQuaternion" {
    shape: rectangle
    style.fill: "#e8f5e9"
    style.stroke: "#2e7d32"
    style.font-size: 11
    style.border-radius: 6
  }
  hashing: "B. Hashing\nMurmurHash2\nMathExtensions" {
    shape: rectangle
    style.fill: "#fff3e0"
    style.stroke: "#e65100"
    style.font-size: 11
    style.border-radius: 6
  }
  memory: "C. Memory\nSpanHelpers\nSpanStream" {
    shape: rectangle
    style.fill: "#e3f2fd"
    style.stroke: "#1565c0"
    style.font-size: 11
    style.border-radius: 6
  }
  collections: "D. Collections\nConcurrentBitmap\nConcurrentArray" {
    shape: rectangle
    style.fill: "#f3e5f5"
    style.stroke: "#6a1b9a"
    style.font-size: 11
    style.border-radius: 6
  }
  locks: "E. Synchronization\nAccessControl\nAccessControlSmall\nAdaptiveWaiter" {
    shape: rectangle
    style.fill: "#fce4ec"
    style.stroke: "#c62828"
    style.font-size: 11
    style.border-radius: 6
  }
  alloc: "F. Allocators\nBlockAllocator\nChainedBlockAllocator\nMemoryAllocator" {
    shape: rectangle
    style.fill: "#fff8e1"
    style.stroke: "#f57f17"
    style.font-size: 11
    style.border-radius: 6
  }
}

# ── Dependency Connections ────────────────────────────────────
consumers.concurrency -> utilities.locks: "" {
  style.stroke: "#c62828"
  style.bold: true
}
consumers.storage -> utilities.collections: "" {
  style.stroke: "#6a1b9a"
}
consumers.storage -> utilities.alloc: "" {
  style.stroke: "#f57f17"
}
consumers.data -> utilities.types: "" {
  style.stroke: "#2e7d32"
}
consumers.data -> utilities.collections: "" {
  style.stroke: "#6a1b9a"
}
consumers.query -> utilities.memory: "" {
  style.stroke: "#1565c0"
}

# All components use hashing
consumers -> utilities.hashing: "all" {
  style.stroke: "#e65100"
  style.bold: true
  style.font-size: 11
}
