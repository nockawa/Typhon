# Typhon Observability Stack - Environment Variables
#
# Override default ports if they conflict with other services.
# Uncomment and modify as needed.

# Grafana UI (default: 3000)
# GRAFANA_PORT=3001

# Jaeger OTLP gRPC receiver (default: 4317)
# JAEGER_OTLP_GRPC_PORT=4317

# Jaeger OTLP HTTP receiver (default: 4318)
# JAEGER_OTLP_HTTP_PORT=4318

# Jaeger UI (default: 16686)
# JAEGER_UI_PORT=16686
