{
  "env": {
    "CLAUDE_CODE_MAX_OUTPUT_TOKENS": "64000"
  },
  "permissions": {
    "allow": [
      "Bash(dotnet build:*)",
      "Bash(dotnet test:*)",
      "Bash(dotnet run:*)",
      "Bash(wait)",
      "Bash(timeout 120 tail:*)",
      "Bash(for i in {1..5})",
      "Bash(do echo \"=== Run $i ===\")",
      "Bash(timeout 15 dotnet test:*)",
      "Bash(echo:*)",
      "Bash(done)",
      "Bash(timeout 20 dotnet test:*)",
      "Bash(timeout:*)",
      "Bash(cat:*)",
      "Bash(wait:*)"
    ],
    "deny": [],
    "ask": []
  },
  "outputStyle": "Explanatory"
}
