{
  "metadata": [
    {
      "src": [
        {
          "files": [
            "**.csproj"
          ],
          "src": "../src"
        }
      ],
      "dest": "api",
      "filter": "filterConfig.yml",
      "includePrivateMembers": true
    }
  ],
  "build": {
    "content": [
      {
        "files": [
          "**/*.{md,yml}"
        ],
        "exclude": [
          "live/**"
        ]
      }
    ],
    "resource": [
      {
        "files": [
          "images/**"
        ]
      }
    ],
    "overwrite": [
      {
        "files": [
          "overview/*.md"
        ]
      }
    ],
    "template": [
      "default",
      "modern",
      "template"
    ],
    "globalMetadata": {
      "_appName": "Typhon",
      "_appTitle": "Typhon",
      "_appFaviconPath": "images/favicon.ico",
      "_appLogoPath": "images/typhon.svg",
      "_appFooter": "Copyright (c) Loïc Baumann",
      "_enableSearch": true,

      "pdf": false
    },
    "dest": "live"
  }
}